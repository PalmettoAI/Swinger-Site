<header class="site-header">
  <div class="wrap">
    <a class="brand-mark" href="/">
      <span class="seal"><%= brand.name.charAt(0) %></span>
      <%= brand.name %>
    </a>

    <% if (currentUser && currentUser.onboarded) { %>
      <button class="nav-toggle" aria-label="Menu" data-nav-toggle>☰</button>
      <nav class="nav-links" id="nav">
        <a href="/browse" class="<%= path.startsWith('/browse') ? 'active' : '' %>">Browse</a>
        <a href="/matches" class="<%= path.startsWith('/matches') ? 'active' : '' %>">Matches</a>
        <a href="/messages" class="<%= path.startsWith('/messages') ? 'active' : '' %>">Messages</a>
        <a href="/events" class="<%= path.startsWith('/events') ? 'active' : '' %>">Events</a>
        <a href="/forum" class="<%= path.startsWith('/forum') ? 'active' : '' %>">Forum</a>
        <% if (currentUser.membership !== 'gold') { %>
          <a href="/membership" class="text-gold">Go Gold</a>
        <% } %>
        <a href="/profile" class="<%= path === '/profile' ? 'active' : '' %>">My Profile</a>
        <a href="/profile/settings">Settings</a>
        <form action="/logout" method="post" style="display:inline">
          <button class="btn btn-ghost btn-sm" type="submit">Sign out</button>
        </form>
      </nav>
    <% } else { %>
      <button class="nav-toggle" aria-label="Menu" data-nav-toggle>☰</button>
      <nav class="nav-links" id="nav">
        <a href="/about" class="<%= path === '/about' ? 'active' : '' %>">About</a>
        <a href="/pricing" class="<%= path === '/pricing' ? 'active' : '' %>">Membership</a>
        <a href="/safety" class="<%= path === '/safety' ? 'active' : '' %>">Safety</a>
        <% if (currentUser) { %>
          <a href="/onboarding" class="btn btn-gold btn-sm">Finish setup</a>
        <% } else { %>
          <a href="/login">Sign in</a>
          <a href="/enter" class="btn btn-primary btn-sm">Join free</a>
        <% } %>
      </nav>
    <% } %>
  </div>
</header>
