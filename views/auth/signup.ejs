<section class="page">
  <div class="wrap narrow">
    <div class="card card-pad rise" style="max-width:520px;margin:0 auto">
      <span class="eyebrow">Create account</span>
      <h1 class="mt-2 mb-2">Join <%= brand.name %></h1>
      <p class="muted mb-4">Free to create a profile. It takes about two minutes.</p>

      <% if (error) { %><div class="alert-inline"><%= error %></div><% } %>

      <form action="/signup" method="post">
        <div class="field">
          <label for="account_type">I'm signing up as a…</label>
          <select name="account_type" id="account_type" required>
            <% Object.keys(accountTypes).forEach(function(key){ %>
              <option value="<%= key %>" <%= values.account_type === key ? 'selected' : '' %>><%= accountTypes[key] %></option>
            <% }) %>
          </select>
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input type="email" name="email" id="email" value="<%= values.email || '' %>" required autocomplete="email" />
        </div>
        <div class="field">
          <label for="password">Password</label>
          <input type="password" name="password" id="password" required minlength="8" autocomplete="new-password" />
          <div class="hint">At least 8 characters.</div>
        </div>
        <label class="switch mb-3">
          <input type="checkbox" name="age_confirm" required />
          <span class="track"></span>
          <span>I confirm I am 18 years or older.</span>
        </label>
        <button class="btn btn-primary btn-block" type="submit">Create my profile</button>
      </form>
      <p class="text-sm muted mt-3 center">
        Already a member? <a href="/login" class="text-gold">Sign in</a>
      </p>
    </div>
  </div>
</section>
