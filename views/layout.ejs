<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : brand.tagline %>" />
  <meta name="robots" content="noindex, nofollow" />
  <meta property="og:title" content="<%= title %>" />
  <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : brand.tagline %>" />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#100b0f" />
  <link rel="icon" href="/static/img/favicon.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="/static/css/app.css" />
</head>
<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %>">
  <%- include('partials/header') %>
  <main>
    <div class="wrap">
      <%- include('partials/flash') %>
    </div>
    <%- body %>
  </main>
  <%- include('partials/footer') %>
  <script src="/static/js/app.js" defer></script>
</body>
</html>
