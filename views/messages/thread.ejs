<section class="page">
  <div class="wrap" style="max-width:820px">
    <a href="/messages" class="text-sm muted">← All messages</a>
    <div class="thread-window mt-2">
      <div class="thread-head">
        <a href="/profile/<%= convo.other_id %>" class="row" style="gap:.7rem">
          <% if (convo.photo) { %><img class="avatar" src="/uploads/<%= convo.photo %>" alt="" />
          <% } else { %><div class="avatar"><%= (convo.display_name||'?').charAt(0).toUpperCase() %></div><% } %>
          <span>
            <strong><%= convo.display_name %></strong>
            <span class="text-sm muted" style="display:block"><%= h.ACCOUNT_TYPES[convo.account_type]||'' %><% if(convo.city){%> · <%= convo.city %>, <%= convo.state %><%}%></span>
          </span>
        </a>
      </div>

      <div class="thread-body" data-thread-body>
        <% if (messages.length === 0) { %>
          <div class="empty-state" style="margin:auto">
            <p>This is the beginning of your conversation with <%= convo.display_name %>.</p>
          </div>
        <% } %>
        <% messages.forEach(function(m){ %>
          <div class="bubble <%= m.from_user === currentUser.id ? 'me' : 'them' %>">
            <%= m.body %>
            <span class="t"><%= h.timeAgo(m.created_at) %></span>
          </div>
        <% }) %>
      </div>

      <form action="/messages/<%= convo.id %>" method="post" class="thread-compose">
        <textarea name="body" placeholder="Write a message…" required maxlength="4000" rows="1"></textarea>
        <button class="btn btn-primary" type="submit">Send</button>
      </form>
    </div>

    <% if (remaining !== null) { %>
      <p class="text-sm muted center mt-2">
        <%= remaining %> free message<%= remaining===1?'':'s' %> left today ·
        <a href="/membership" class="text-gold">Go Gold for unlimited</a>
      </p>
    <% } %>
  </div>
</section>
