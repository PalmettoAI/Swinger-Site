<section class="page">
  <div class="wrap" style="max-width:900px">
    <a href="/events" class="text-sm muted">← All events</a>

    <div class="card mt-2" style="overflow:hidden">
      <div class="ecover" style="aspect-ratio:21/7"><%= event.title.charAt(0) %></div>
      <div class="card-pad">
        <div class="etype" style="color:var(--gold);letter-spacing:.16em;text-transform:uppercase;font-size:.72rem"><%= eventTypes[event.event_type] %></div>
        <h1 class="mt-2"><%= event.title %></h1>
        <div class="event-meta mt-2" style="font-size:1rem">
          <span>📅 <%= h.formatEventDate(event.starts_at) %><% if (event.ends_at) { %> – <%= h.formatEventDate(event.ends_at) %><% } %></span>
        </div>
        <div class="event-meta">
          <% if (event.venue) { %><span>📍 <%= event.venue %></span><% } %>
          <% if (event.city) { %><span><%= event.city %><% if(event.state){%>, <%= event.state %><%}%></span><% } %>
        </div>
        <% if (event.host_name) { %><p class="text-sm muted mt-2">Hosted by <a href="/profile/<%= event.host_id %>" class="text-gold"><%= event.host_name %></a></p><% } %>

        <div class="profile-actions">
          <form action="/events/<%= event.id %>/rsvp" method="post">
            <input type="hidden" name="status" value="<%= myRsvp==='going' ? 'none' : 'going' %>" />
            <button class="btn <%= myRsvp==='going' ? 'btn-ghost' : 'btn-primary' %>" type="submit"><%= myRsvp==='going' ? '✓ Going' : "I'm going" %></button>
          </form>
          <form action="/events/<%= event.id %>/rsvp" method="post">
            <input type="hidden" name="status" value="<%= myRsvp==='interested' ? 'none' : 'interested' %>" />
            <button class="btn btn-ghost" type="submit"><%= myRsvp==='interested' ? '★ Interested' : 'Interested' %></button>
          </form>
        </div>

        <% if (event.description) { %>
          <div class="about-block"><%= event.description %></div>
        <% } %>

        <div class="deco-rule"><span><%= attendees.length %> attending</span></div>
        <% if (attendees.length) { %>
          <div class="member-grid">
            <% attendees.forEach(function(a){ %>
              <a href="/profile/<%= a.id %>" class="member-card">
                <div class="member-photo">
                  <% if (a.photo) { %><img src="/uploads/<%= a.photo %>" alt="" loading="lazy" />
                  <% } else { %><div class="placeholder"><%= (a.display_name||'?').charAt(0).toUpperCase() %></div><% } %>
                </div>
                <div class="meta"><div class="name" style="font-size:1rem"><%= a.display_name %></div><div class="sub"><%= a.status %></div></div>
              </a>
            <% }) %>
          </div>
        <% } else { %>
          <p class="muted">No RSVPs yet — be the first.</p>
        <% } %>
      </div>
    </div>
  </div>
</section>
