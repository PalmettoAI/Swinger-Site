<section class="page">
  <div class="wrap narrow">
    <div class="row between wrap-gap mb-4">
      <div>
        <h1 class="page-title">Your photos</h1>
        <p class="page-lead"><%= photos.length %> of <%= limit %> used · Private photos stay locked until you grant access.</p>
      </div>
      <a href="/profile" class="btn btn-ghost btn-sm">View my profile</a>
    </div>

    <% if (requests && requests.length) { %>
      <div class="card card-pad mb-4">
        <h3 class="mb-2">Private gallery requests</h3>
        <% requests.forEach(function(r){ %>
          <div class="row between mb-2">
            <span><a href="/profile/<%= r.viewer_id %>" class="text-gold"><%= r.display_name %></a> requested access</span>
            <span class="row">
              <form action="/photos/access/<%= r.viewer_id %>/grant" method="post"><button class="btn btn-primary btn-sm" type="submit">Grant</button></form>
              <form action="/photos/access/<%= r.viewer_id %>/deny" method="post"><button class="btn btn-ghost btn-sm" type="submit">Deny</button></form>
            </span>
          </div>
        <% }) %>
      </div>
    <% } %>

    <% if (photos.length < limit) { %>
      <form action="/photos/upload" method="post" enctype="multipart/form-data" class="uploader mb-4">
        <div class="ficon" style="font-size:2rem">＋</div>
        <p class="muted mb-3">JPG, PNG, WebP or GIF · up to 8&nbsp;MB</p>
        <input type="file" name="photo" accept="image/*" required style="max-width:340px;margin:0 auto" />
        <label class="switch mt-3" style="justify-content:center">
          <input type="checkbox" name="is_private" />
          <span class="track"></span> Upload as private (locked)
        </label>
        <div class="mt-3"><button class="btn btn-primary" type="submit">Upload photo</button></div>
      </form>
    <% } else { %>
      <div class="panel mb-4 center">
        You've reached your <%= limit %>-photo limit.
        <% if (typeof currentUser !== 'undefined' && currentUser.membership !== 'gold') { %>
          <a href="/membership" class="text-gold">Upgrade to Gold</a> for up to 30.
        <% } %>
      </div>
    <% } %>

    <% if (photos.length) { %>
      <div class="photo-grid">
        <% photos.forEach(function(p){ %>
          <div class="photo-tile">
            <div class="ph-img <%= p.is_private ? 'locked' : '' %>">
              <img src="/uploads/<%= p.filename %>" alt="" />
              <% if (p.is_private) { %><span class="pill badge-private">🔒 Private</span><% } %>
              <% if (p.is_primary) { %><span class="pill pill-gold badge-private" style="top:auto;bottom:.4rem">★ Primary</span><% } %>
            </div>
            <div class="ph-bar">
              <% if (!p.is_private && !p.is_primary) { %>
                <form action="/photos/<%= p.id %>/primary" method="post"><button class="btn btn-ghost btn-sm" type="submit">Make primary</button></form>
              <% } %>
              <form action="/photos/<%= p.id %>/privacy" method="post"><button class="btn btn-ghost btn-sm" type="submit"><%= p.is_private ? 'Make public' : 'Make private' %></button></form>
              <form action="/photos/<%= p.id %>/delete" method="post" onsubmit="return confirm('Delete this photo?')"><button class="btn btn-ghost btn-sm" type="submit">Delete</button></form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <div class="center mt-5">
      <a href="/browse" class="btn btn-gold">Done — start browsing</a>
    </div>
  </div>
</section>
