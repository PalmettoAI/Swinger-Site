# ─── Core ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
SESSION_SECRET=change-me-to-a-long-random-string

# ─── Branding (white-label ready) ───────────────────────────────────
BRAND_NAME=Velvet
BRAND_TAGLINE=The lifestyle, elevated.
SUPPORT_EMAIL=support@velvet.example
LEGAL_NAME=Velvet Social LLC

# ─── Database (Railway sets DATABASE_URL automatically) ─────────────
DATABASE_URL=postgres://user:pass@localhost:5432/velvet
PGSSL=false

# ─── Uploads ────────────────────────────────────────────────────────
# In production attach a Railway Volume mounted here, or switch to R2/S3.
UPLOAD_DIR=./uploads
UPLOAD_MAX_BYTES=8388608

# ─── Membership / limits ────────────────────────────────────────────
FREE_MSG_LIMIT=5
FREE_PHOTO_LIMIT=3
GOLD_PHOTO_LIMIT=30

# ─── Payments (high-risk processor — Stripe/PayPal ban adult) ───────
PAYMENT_PROVIDER=ccbill
CCBILL_ACCNUM=
CCBILL_SUBACC=
CCBILL_FLEXFORM_ID=
CCBILL_SALT=
# Dev-only: instantly flip tier to Gold without a real charge (NEVER true in prod)
DEV_INSTANT_UPGRADE=true

# ─── Demo data ──────────────────────────────────────────────────────
# Seeds sample profiles/events so the platform isn't empty during dev/demo.
SEED_DEMO=false
